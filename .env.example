# ─── Bot ──────────────────────────────────────────────────────────────────────
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Mode: polling | webhook ──────────────────────────────────────────────────
BOT_MODE=polling

# Webhook settings (only needed if BOT_MODE=webhook)
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8443

# ─── Database: sqlite | postgres ─────────────────────────────────────────────
DB_TYPE=sqlite

# PostgreSQL (only needed if DB_TYPE=postgres)
POSTGRES_DSN=postgresql://user:password@localhost:5432/queuebot

# ─── Web panel ────────────────────────────────────────────────────────────────
WEB_PANEL_ENABLED=true
WEB_PANEL_PORT=8080
WEB_PANEL_PASSWORD=changeme

# ─── Notifications ────────────────────────────────────────────────────────────
# Warn user when they are <= N places from first (0 = disabled)
NOTIFY_APPROACHING=3

# твой Telegram user_id — узнать можно у @userinfobot
BOT_OWNER_ID=0
